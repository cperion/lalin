end

-- ╔════════════════════════════════════════════════════════════════════════════╗
-- ║ PART 6: PUBLIC API EXPORTS                                                 ║
-- ╚════════════════════════════════════════════════════════════════════════════╝

M.mb_push_cmd = mb_push_cmd
M.mb_push_cmd_w10 = mb_push_cmd_w10
M.mb_fresh_val = mb_fresh_val
M.mb_is_float_scalar = mb_is_float_scalar
M.mb_is_signed_scalar = mb_is_signed_scalar
M.mb_token_to_unary_op = mb_token_to_unary_op
M.mb_token_to_binary_op = mb_token_to_binary_op
M.mb_token_to_cmp_op = mb_token_to_cmp_op
M.mb_env_empty = mb_env_empty
M.mb_env_add_scalar = mb_env_add_scalar
M.mb_env_lookup = mb_env_lookup
M.mb_env_next_value = mb_env_next_value
M.mb_env_next_block = mb_env_next_block
M.mb_lower_lit_region = mb_lower_lit_region
M.mb_lower_ref_region = mb_lower_ref_region
M.mb_lower_unary_region = mb_lower_unary_region
M.mb_lower_binary_region = mb_lower_binary_region
M.back_lower_func = back_lower_func
M.back_lower_module = back_lower_module

return M
end
