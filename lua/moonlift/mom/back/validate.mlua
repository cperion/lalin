-- MOM backend validation — full structural validator.
--
-- Walks Cmd tape, reads data fields (a-f) per variant,
-- maintains declaration tables for all symbol classes.
-- All mutable state via block loop parameters (Moonlift SSA discipline).

local M = moon.module("mom_back_validate")

-- Issue tags from MoonBack BackValidationIssue.
local ISS_EMPTY_PROGRAM = 1
local ISS_MISSING_FINALIZE = 2
local ISS_CMD_AFTER_FINALIZE = 3
local ISS_CMD_OUTSIDE_FUNC = 4
local ISS_NESTED_FUNC = 5
local ISS_FINISH_WITHOUT_BEGIN = 6
local ISS_FINISH_WRONG_FUNC = 7
local ISS_UNFINISHED_FUNC = 8
local ISS_DUP_SIG = 9
local ISS_DUP_DATA = 10
local ISS_DUP_FUNC = 11
local ISS_DUP_EXTERN = 12
local ISS_DUP_BLOCK = 13
local ISS_DUP_SLOT = 14
local ISS_DUP_VALUE = 15
local ISS_DUP_ACCESS = 16
local ISS_MISSING_SIG = 17
local ISS_MISSING_DATA = 18
local ISS_MISSING_FUNC = 19
local ISS_MISSING_EXTERN = 20
local ISS_MISSING_BLOCK = 21
local ISS_MISSING_SLOT = 22
local ISS_MISSING_VALUE = 23
local ISS_MISSING_ACCESS = 24

-- Cmd variant tags (from MoonBack schema declaration order).
local C_TM = 1
local C_CSIG = 2; local C_DECD = 3; local C_DIZ = 4; local C_DI = 5; local C_DA = 6
local C_FA = 7; local C_EA = 8; local C_DF = 9; local C_DE = 10; local C_BF = 11
local C_CB = 12; local C_STB = 13; local C_SLB = 14; local C_BEP = 15; local C_ABP = 16
local C_CSS = 17; local C_AL = 18; local C_SA = 19; local C_CO = 20; local C_UN = 21
local C_IN = 22; local C_CP = 23; local C_CA = 24; local C_PO = 25; local C_LI = 26
local C_SI = 27; local C_ALO = 28; local C_ASO = 29; local C_ARM = 30; local C_ACA = 31
local C_AF = 32; local C_IB = 33; local C_BB = 34; local C_BN = 35; local C_SH = 36
local C_RO = 37; local C_FB = 38; local C_AFT = 39; local C_MC = 40; local C_MS = 41
local C_SE = 42; local C_FM = 43; local C_VS = 44; local C_VB = 45; local C_VC = 46
local C_VSE = 47; local C_VM = 48; local C_VIL = 49; local C_VEL = 50; local C_CL = 51
local C_JU = 52; local C_BI = 53; local C_SWI = 54; local C_RV = 55; local C_RVV = 56
local C_TR = 57; local C_FF = 58; local C_FMZ = 59

-- Push an issue entry.
local mb_push = func(tag: i32, a: i32, b: i32, c: i32,
                      it: ptr(i32), ia: ptr(i32), ib: ptr(i32), ic: ptr(i32),
                      cnt: ptr(i32), cap: i32)
    let i: i32 = cnt[0]
    if i < cap then it[i] = tag; ia[i] = a; ib[i] = b; ic[i] = c end
    cnt[0] = i + 1
end

-- Linear-scan map ops.
local mb_has = func(st: ptr(i32), key: ptr(i32), k: i32, cap: i32) -> i32
    block sc(i: i32 = 0)
        if i >= cap then return 0 end
        if st[i] == 1 and key[i] == k then return 1 end
        jump sc(i = i + 1)
    end
    return 0
end

local mb_add = func(st: ptr(i32), key: ptr(i32), k: i32, cap: i32) -> i32
    if mb_has(st, key, k, cap) ~= 0 then return 1 end
    block ins(i: i32 = 0)
        if i >= cap then return 1 end
        if st[i] == 0 then st[i] = 1; key[i] = k; return 0 end
        jump ins(i = i + 1)
    end
    return 1
end

-- Full validator. Reads tag + 6 data fields per Cmd.
-- Uses block params i (index), act (active_func id), fin (finalize seen).
-- Maps: 0=sig 1=data 2=func 3=extern 4=block 5=slot 6=value 7=access
local mb_validate = func(ct: ptr(i32), ca: ptr(i32), cb: ptr(i32), cc: ptr(i32),
                          cd: ptr(i32), ce: ptr(i32), cf: ptr(i32), n: i32,
                          it: ptr(i32), ia: ptr(i32), ib: ptr(i32), ic: ptr(i32),
                          icnt: ptr(i32), icap: i32,
                          ms: ptr(i32), mk: ptr(i32), mcap: i32) -> i32
    let MS = 0; let MD = 1; let MF = 2; let ME = 3
    let MB = 4; let MSL = 5; let MV = 6; let MA = 7

    if n == 0 then
        mb_push(@{ISS_EMPTY_PROGRAM}, 0,0,0, it,ia,ib,ic, icnt,icap)
        mb_push(@{ISS_MISSING_FINALIZE}, 0,0,0, it,ia,ib,ic, icnt,icap)
        return icnt[0]
    end

    block lp(i: i32 = 0, act: i32 = -1, fin: i32 = 0)
        if i >= n then
            if act >= 0 then mb_push(@{ISS_UNFINISHED_FUNC}, act,0,0, it,ia,ib,ic, icnt,icap) end
            if fin == 0 then mb_push(@{ISS_MISSING_FINALIZE}, 0,0,0, it,ia,ib,ic, icnt,icap) end
            return icnt[0]
        end
        if fin ~= 0 then
            mb_push(@{ISS_CMD_AFTER_FINALIZE}, i,0,0, it,ia,ib,ic, icnt,icap)
            jump lp(i = i+1, act=act, fin=fin)
        end

        let tg: i32 = ct[i]
        let a: i32 = ca[i]; let b: i32 = cb[i]; let c: i32 = cc[i]
        let d: i32 = cd[i]; let e: i32 = ce[i]; let f: i32 = cf[i]

        -- CmdFinalizeModule (59)
        if tg == @{C_FMZ} then jump lp(i = i+1, act=act, fin=1) end

        -- ── Sig declarations/references ──
        if tg == @{C_CSIG} then
            if mb_add(ms+MS*mcap, mk+MS*mcap, a, mcap) ~= 0 then
                mb_push(@{ISS_DUP_SIG}, i,a,0, it,ia,ib,ic, icnt,icap)
            end
            jump lp(i = i+1, act=act, fin=fin)
        end
        -- CmdDeclareFunc references sig via c
        if tg == @{C_DF} then
            if mb_has(ms+MS*mcap, mk+MS*mcap, c, mcap) == 0 then
                mb_push(@{ISS_MISSING_SIG}, i,c,0, it,ia,ib,ic, icnt,icap)
            end
            -- Declare func via b
            if mb_add(ms+MF*mcap, mk+MF*mcap, b, mcap) ~= 0 then
                mb_push(@{ISS_DUP_FUNC}, i,b,0, it,ia,ib,ic, icnt,icap)
            end
            jump lp(i = i+1, act=act, fin=fin)
        end
        -- CmdDeclareExtern references sig via c
        if tg == @{C_DE} then
            if mb_has(ms+MS*mcap, mk+MS*mcap, c, mcap) == 0 then
                mb_push(@{ISS_MISSING_SIG}, i,c,0, it,ia,ib,ic, icnt,icap)
            end
            -- Declare extern via a
            if mb_add(ms+ME*mcap, mk+ME*mcap, a, mcap) ~= 0 then
                mb_push(@{ISS_DUP_EXTERN}, i,a,0, it,ia,ib,ic, icnt,icap)
            end
            jump lp(i = i+1, act=act, fin=fin)
        end

        -- ── Data declarations/references ──
        if tg == @{C_DECD} then
            if mb_add(ms+MD*mcap, mk+MD*mcap, a, mcap) ~= 0 then
                mb_push(@{ISS_DUP_DATA}, i,a,0, it,ia,ib,ic, icnt,icap)
            end
            jump lp(i = i+1, act=act, fin=fin)
        end
        -- CmdDataAddr, CmdDataInitZero, CmdDataInit reference data
        if tg == @{C_DA} or tg == @{C_DIZ} or tg == @{C_DI} then
            let did: i32 = select(tg == @{C_DA}, b, a)  -- CmdDataAddr uses b, Init variants use a
            if mb_has(ms+MD*mcap, mk+MD*mcap, did, mcap) == 0 then
                mb_push(@{ISS_MISSING_DATA}, i,did,0, it,ia,ib,ic, icnt,icap)
            end
            jump lp(i = i+1, act=act, fin=fin)
        end

        -- ── Func/extern addr references ──
        if tg == @{C_FA} then
            if mb_has(ms+MF*mcap, mk+MF*mcap, b, mcap) == 0 then
                mb_push(@{ISS_MISSING_FUNC}, i,b,0, it,ia,ib,ic, icnt,icap)
            end
            jump lp(i = i+1, act=act, fin=fin)
        end
        if tg == @{C_EA} then
            if mb_has(ms+ME*mcap, mk+ME*mcap, b, mcap) == 0 then
                mb_push(@{ISS_MISSING_EXTERN}, i,b,0, it,ia,ib,ic, icnt,icap)
            end
            jump lp(i = i+1, act=act, fin=fin)
        end

        -- ── Function scoping ──
        if tg == @{C_BF} then
            if act >= 0 then mb_push(@{ISS_NESTED_FUNC}, i,act,a, it,ia,ib,ic, icnt,icap) end
            jump lp(i = i+1, act=a, fin=fin)
        end
        if tg == @{C_FF} then
            if act < 0 then
                mb_push(@{ISS_FINISH_WITHOUT_BEGIN}, i,a,0, it,ia,ib,ic, icnt,icap)
            elseif act ~= a then
                mb_push(@{ISS_FINISH_WRONG_FUNC}, i,act,a, it,ia,ib,ic, icnt,icap)
            end
            jump lp(i = i+1, act=-1, fin=fin)
        end

        -- ── Block declarations/references ──
        if tg == @{C_CB} then
            if act < 0 then mb_push(@{ISS_CMD_OUTSIDE_FUNC}, i,0,0, it,ia,ib,ic, icnt,icap)
            elseif mb_add(ms+MB*mcap, mk+MB*mcap, a, mcap) ~= 0 then
                mb_push(@{ISS_DUP_BLOCK}, i,a,0, it,ia,ib,ic, icnt,icap)
            end
            jump lp(i = i+1, act=act, fin=fin)
        end
        if tg == @{C_STB} or tg == @{C_SLB} then
            if act < 0 then mb_push(@{ISS_CMD_OUTSIDE_FUNC}, i,0,0, it,ia,ib,ic, icnt,icap)
            elseif mb_has(ms+MB*mcap, mk+MB*mcap, a, mcap) == 0 then
                mb_push(@{ISS_MISSING_BLOCK}, i,a,0, it,ia,ib,ic, icnt,icap)
            end
            jump lp(i = i+1, act=act, fin=fin)
        end
        -- CmdJump, CmdSwitchInt default_block, CmdBrIf then/else blocks
        if tg == @{C_JU} then
            if act < 0 then mb_push(@{ISS_CMD_OUTSIDE_FUNC}, i,0,0, it,ia,ib,ic, icnt,icap)
            elseif mb_has(ms+MB*mcap, mk+MB*mcap, a, mcap) == 0 then
                mb_push(@{ISS_MISSING_BLOCK}, i,a,0, it,ia,ib,ic, icnt,icap)
            end
            jump lp(i = i+1, act=act, fin=fin)
        end
        if tg == @{C_BI} then
            if act < 0 then mb_push(@{ISS_CMD_OUTSIDE_FUNC}, i,0,0, it,ia,ib,ic, icnt,icap)
            else
                if mb_has(ms+MB*mcap, mk+MB*mcap, b, mcap) == 0 then
                    mb_push(@{ISS_MISSING_BLOCK}, i,b,0, it,ia,ib,ic, icnt,icap)
                end
                if mb_has(ms+MB*mcap, mk+MB*mcap, d, mcap) == 0 then
                    mb_push(@{ISS_MISSING_BLOCK}, i,d,0, it,ia,ib,ic, icnt,icap)
                end
            end
            jump lp(i = i+1, act=act, fin=fin)
        end
        if tg == @{C_SWI} then
            if act < 0 then mb_push(@{ISS_CMD_OUTSIDE_FUNC}, i,0,0, it,ia,ib,ic, icnt,icap)
            elseif mb_has(ms+MB*mcap, mk+MB*mcap, d, mcap) == 0 then
                mb_push(@{ISS_MISSING_BLOCK}, i,d,0, it,ia,ib,ic, icnt,icap)
            end
            jump lp(i = i+1, act=act, fin=fin)
        end

        -- ── Stack slot ──
        if tg == @{C_CSS} then
            if act < 0 then mb_push(@{ISS_CMD_OUTSIDE_FUNC}, i,0,0, it,ia,ib,ic, icnt,icap)
            elseif mb_add(ms+MSL*mcap, mk+MSL*mcap, a, mcap) ~= 0 then
                mb_push(@{ISS_DUP_SLOT}, i,a,0, it,ia,ib,ic, icnt,icap)
            end
            jump lp(i = i+1, act=act, fin=fin)
        end
        if tg == @{C_SA} then
            if act < 0 then mb_push(@{ISS_CMD_OUTSIDE_FUNC}, i,0,0, it,ia,ib,ic, icnt,icap)
            elseif mb_has(ms+MSL*mcap, mk+MSL*mcap, b, mcap) == 0 then
                mb_push(@{ISS_MISSING_SLOT}, i,b,0, it,ia,ib,ic, icnt,icap)
            end
            jump lp(i = i+1, act=act, fin=fin)
        end

        -- ── Value-defining cmds (dst in a) ──
        if tg == @{C_CO} or tg == @{C_UN} or tg == @{C_IN} or tg == @{C_CP}
            or tg == @{C_CA} or tg == @{C_IB} or tg == @{C_BB} or tg == @{C_BN}
            or tg == @{C_SH} or tg == @{C_RO} or tg == @{C_FB} or tg == @{C_SE}
            or tg == @{C_FM} or tg == @{C_VS} or tg == @{C_VB} or tg == @{C_VC}
            or tg == @{C_VSE} or tg == @{C_VM} or tg == @{C_VIL} or tg == @{C_VEL}
            or tg == @{C_AL} or tg == @{C_PO} or tg == @{C_LI} or tg == @{C_ALO}
            or tg == @{C_ARM} or tg == @{C_ACA}
        then
            if act < 0 then mb_push(@{ISS_CMD_OUTSIDE_FUNC}, i,0,0, it,ia,ib,ic, icnt,icap)
            elseif mb_add(ms+MV*mcap, mk+MV*mcap, a, mcap) ~= 0 then
                mb_push(@{ISS_DUP_VALUE}, i,a,0, it,ia,ib,ic, icnt,icap)
            end
            jump lp(i = i+1, act=act, fin=fin)
        end

        -- ── Value-referencing cmds (value use in various fields) ──
        -- CmdReturnValue
        if tg == @{C_RVV} then
            if act < 0 then mb_push(@{ISS_CMD_OUTSIDE_FUNC}, i,0,0, it,ia,ib,ic, icnt,icap)
            elseif mb_has(ms+MV*mcap, mk+MV*mcap, a, mcap) == 0 then
                mb_push(@{ISS_MISSING_VALUE}, i,a,0, it,ia,ib,ic, icnt,icap)
            end
            jump lp(i = i+1, act=act, fin=fin)
        end
        -- CmdBindEntryParams: values view in b
        if tg == @{C_BEP} then
            if act < 0 then mb_push(@{ISS_CMD_OUTSIDE_FUNC}, i,0,0, it,ia,ib,ic, icnt,icap) end
            jump lp(i = i+1, act=act, fin=fin)
        end
        -- CmdCall: sig ref in c
        if tg == @{C_CL} then
            if act < 0 then mb_push(@{ISS_CMD_OUTSIDE_FUNC}, i,0,0, it,ia,ib,ic, icnt,icap)
            elseif mb_has(ms+MS*mcap, mk+MS*mcap, c, mcap) == 0 then
                mb_push(@{ISS_MISSING_SIG}, i,c,0, it,ia,ib,ic, icnt,icap)
            end
            jump lp(i = i+1, act=act, fin=fin)
        end
        -- CmdStoreInfo: value in c, CmdAtomicStore: value in c
        if tg == @{C_SI} or tg == @{C_ASO} then
            if act < 0 then mb_push(@{ISS_CMD_OUTSIDE_FUNC}, i,0,0, it,ia,ib,ic, icnt,icap) end
            jump lp(i = i+1, act=act, fin=fin)
        end

        -- Cmds valid inside or outside a function
        if tg == @{C_TM} then jump lp(i = i+1, act=act, fin=fin) end
        if tg == @{C_RV} or tg == @{C_TR} then
            if act < 0 then mb_push(@{ISS_CMD_OUTSIDE_FUNC}, i,0,0, it,ia,ib,ic, icnt,icap) end
            jump lp(i = i+1, act=act, fin=fin)
        end
        -- CmdBpp: AppendBlockParam, CmdAliasFact, CmdMemcpy/Memset
        if tg == @{C_ABP} or tg == @{C_AFT} or tg == @{C_MC} or tg == @{C_MS}
            or tg == @{C_AF}
        then
            if act < 0 then mb_push(@{ISS_CMD_OUTSIDE_FUNC}, i,0,0, it,ia,ib,ic, icnt,icap) end
            jump lp(i = i+1, act=act, fin=fin)
        end

        jump lp(i = i+1, act=act, fin=fin)
    end
    return icnt[0]
end

M:add_func(mb_push)
M:add_func(mb_has)
M:add_func(mb_add)
M:add_func(mb_validate)
return M
