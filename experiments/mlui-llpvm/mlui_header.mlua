-- -----------------------------------------------------------------------------
-- Kernel and store protocols.
-- -----------------------------------------------------------------------------

R.ui_kernel_create = region ui_kernel_create(config: ptr(@{T.UiConfig});
    created(kernel: owned @{T.UiKernelRef})
  | oom(needed: index)) end

R.ui_kernel_borrow = region ui_kernel_borrow(kernel: @{T.UiKernelRef};
    borrowed(ui: lease ptr(@{T.UiKernel}))
  | missing(kernel: @{T.UiKernelRef})
  | stale(kernel: @{T.UiKernelRef})) end

R.ui_kernel_close_ref = region ui_kernel_close_ref(kernel: owned @{T.UiKernelRef};
    closed
  | busy(kernel: owned @{T.UiKernelRef})
  | missing(kernel: owned @{T.UiKernelRef})
  | stale(kernel: owned @{T.UiKernelRef})) end

R.ui_kernel_init_ptr = region ui_kernel_init_ptr(config: ptr(@{T.UiConfig});
    created(ui: ptr(@{T.UiKernel}))
  | bad_argument(code: i32)
  | oom(needed: index)) end

R.ui_kernel_close_ptr = region ui_kernel_close_ptr(ui: ptr(@{T.UiKernel});
    closed
  | busy
  | bad_argument(code: i32)) end

R.ui_reset_auth = region ui_reset_auth(ui: ptr(@{T.UiKernel});
    reset
  | oom(needed: index)) end

R.ui_reset_scene = region ui_reset_scene(ui: ptr(@{T.UiKernel});
    reset
  | oom(needed: index)) end

R.ui_reset_solve = region ui_reset_solve(ui: ptr(@{T.UiKernel});
    reset
  | oom(needed: index)) end

R.ui_reset_view = region ui_reset_view(ui: ptr(@{T.UiKernel});
    reset
  | oom(needed: index)) end

R.ui_reset_frame_events = region ui_reset_frame_events(ui: ptr(@{T.UiKernel});
    reset
  | oom(needed: index)) end

-- -----------------------------------------------------------------------------
-- Program validation, import, and compiler pipeline protocols.
-- -----------------------------------------------------------------------------

R.ui_validate_program = region ui_validate_program(ui: ptr(@{T.UiKernel}), readonly program: ptr(@{T.UiProgram});
    valid(root_kind: u8, root_index: u32)
  | invalid_header(code: i32)
  | invalid_section(section: u8)
  | invalid_opcode(at: index, kind: u16)
  | invalid_range(section: u8, first: u32, count: u32)
  | invalid_arity(at: index, expected: u32, got: u32)
  | duplicate_id(id: u64)
  | missing_resource(section: u8, index_: u32)
  | unsupported_feature(flags: u64)
  | oom(needed: index)) end

R.ui_validate_llpv_program = region ui_validate_llpv_program(ui: ptr(@{T.UiKernel}), readonly bytes: ptr(u8), byte_len: index;
    valid(root_stream: u32)
  | invalid_header(code: i32)
  | invalid_section(section: u8)
  | invalid_opcode(at: index, kind: u16)
  | unsupported_feature(flags: u64)
  | oom(needed: index)) end

R.ui_import_auth = region ui_import_auth(ui: ptr(@{T.UiKernel}), readonly program: ptr(@{T.UiProgram}), root_kind: u8, root_index: u32;
    imported(root: @{T.UiNodeRef})
  | invalid_child(parent: u64, child_index: u32)
  | duplicate_id(id: u64)
  | missing_resource(section: u8, index_: u32)
  | unsupported_node(kind: u16)
  | oom(needed: index)) end

R.ui_import_auth_buffer = region ui_import_auth_buffer(ui: ptr(@{T.UiKernel}), readonly nodes: view(@{T.UiAuthNode}), readonly children: view(u32);
    imported(root: @{T.UiNodeRef})
  | invalid_child(parent: u64, child_index: u32)
  | duplicate_id(id: u64)
  | unsupported_node(kind: u16)
  | oom(needed: index)) end

R.ui_import_llpv_program = region ui_import_llpv_program(ui: ptr(@{T.UiKernel}), readonly bytes: ptr(u8), byte_len: index;
    imported(root: @{T.UiNodeRef})
  | invalid_header(code: i32)
  | invalid_opcode(at: index, kind: u16)
  | unsupported_feature(flags: u64)
  | oom(needed: index)) end

R.ui_expand_compose = region ui_expand_compose(ui: ptr(@{T.UiKernel}), readonly compose: view(@{T.UiComposeNode});
    expanded(auth: @{T.UiAuthBuffer})
  | invalid_child(parent: u64, child_index: u32)
  | unsupported_compose(kind: u16)
  | oom(needed: index)) end

R.ui_resolve_style = region ui_resolve_style(ui: ptr(@{T.UiKernel}), token_range: @{T.UiRange}, env: @{T.UiEnvClass}, state: @{T.UiStateFacts};
    resolved(layout: @{T.UiLayoutStyle}, decor: @{T.UiDecorStyle}, interact: @{T.UiInteractionStyle})
  | invalid_atom(kind: u16)
  | missing_theme(id: u64)
  | missing_resource(section: u8, index_: u32)
  | oom(needed: index)) end

R.ui_lower_scene = region ui_lower_scene(ui: ptr(@{T.UiKernel}), root: @{T.UiNodeRef}, env: @{T.UiEnvClass};
    lowered(scene_epoch: u64)
  | missing_node(id: u64)
  | duplicate_id(id: u64)
  | unsupported_node(kind: u16)
  | oom(needed: index)) end

R.ui_measure_node = region ui_measure_node(ui: ptr(@{T.UiKernel}), layout_index: u32, constraint: @{T.UiMeasureConstraint};
    measured(size: @{T.UiIntrinsicSize}, text_layout: @{T.UiTextLayoutRef})
  | missing_text(content: @{T.UiContentRef})
  | text_backend_error(code: i32)
  | unsupported_layout(kind: u16)
  | oom(needed: index)) end

R.ui_measure_scene = region ui_measure_scene(ui: ptr(@{T.UiKernel}), constraint: @{T.UiMeasureConstraint};
    measured(measure_epoch: u64)
  | missing_scene
  | missing_text(content: @{T.UiContentRef})
  | text_backend_error(code: i32)
  | unsupported_layout(kind: u16)
  | oom(needed: index)) end

R.ui_solve_scene = region ui_solve_scene(ui: ptr(@{T.UiKernel}), viewport: @{T.UiViewport};
    solved(solve_epoch: u64)
  | missing_scene
  | missing_text(content: @{T.UiContentRef})
  | text_backend_error(code: i32)
  | unsupported_layout(kind: u16)
  | oom(needed: index)) end

R.ui_render_ops = region ui_render_ops(ui: ptr(@{T.UiKernel});
    rendered(view_epoch: u64)
  | missing_node(id: u64)
  | missing_text(content: @{T.UiContentRef})
  | decor_mismatch(layout_index: u32, decor_index: u32)
  | malformed_op(at: index, kind: u16)
  | oom(needed: index)) end

R.ui_runtime_report = region ui_runtime_report(ui: ptr(@{T.UiKernel});
    reported(report_epoch: u64)
  | malformed_op(at: index, kind: u16)
  | stack_unbalanced(stack: u8)
  | oom(needed: index)) end

R.ui_interact_step = region ui_interact_step(ui: ptr(@{T.UiKernel}), readonly raw: view(@{T.UiRawInput});
    stepped(event_count: index, model_epoch: u64)
  | malformed_raw(at: index, kind: u16)
  | stale_focus(id: u64)
  | stale_capture(id: u64)
  | missing_scroll(id: u64)
  | text_input_without_focus(at: index)
  | oom(needed: index)) end

-- -----------------------------------------------------------------------------
-- Visitor protocols.  These are the only owners of raw kind decoding.
-- -----------------------------------------------------------------------------

R.ui_visit_style_atom = region ui_visit_style_atom(atom: @{T.UiStyleAtom};
    display(value: u16)
  | position(value: u16)
  | length(kind: u16, value: f32)
  | spacing(kind: u16, insets: @{T.UiInsets})
  | color(kind: u16, color: @{T.UiColor})
  | font(kind: u16, font_ref: @{T.UiFontRef})
  | interaction(kind: u16, policy: u16)
  | user(kind: u16, a: u32, b: u32, c: u32)
  | unknown(kind: u16)) end

R.ui_visit_compose_node = region ui_visit_compose_node(node: @{T.UiComposeNode};
    panel
  | scroll_panel(axis: u8)
  | hsplit
  | vsplit
  | workbench
  | unknown(kind: u16)) end

R.ui_visit_auth_node = region ui_visit_auth_node(node: @{T.UiAuthNode};
    empty
  | fragment(children: @{T.UiRange})
  | box(children: @{T.UiRange})
  | text(content: @{T.UiContentRef})
  | text_inline(content: @{T.UiContentRef})
  | text_ref(layout: @{T.UiTextLayoutRef})
  | paint(paint_first: u32, paint_count: u32)
  | canvas(value: @{T.UiValueRef})
  | image(image: @{T.UiImageRef})
  | scroll(axis: u8, child_index: u32)
  | input_surface(role: u8, child_index: u32)
  | drag_source(child_index: u32)
  | drop_target(child_index: u32)
  | focus_scope(children: @{T.UiRange})
  | layer(order: i32, child_index: u32)
  | overlay(anchor_id: u64, child_index: u32)
  | modal(child_index: u32)
  | text_field(content: @{T.UiContentRef})
  | slot(value: @{T.UiValueRef})
  | unknown(kind: u16)) end

R.ui_visit_layout_node = region ui_visit_layout_node(node: @{T.UiLayoutNode};
    empty
  | fragment
  | flow
  | flex(axis: u8)
  | grid
  | leaf(kind: u16)
  | wrapper(kind: u16)
  | unknown(kind: u16)) end

R.ui_visit_decor_node = region ui_visit_decor_node(node: @{T.UiDecorNode};
    none
  | box
  | text
  | paint
  | image
  | cursor(cursor: u16)
  | hit(role: u8, policy: u16)
  | focus(policy: u16)
  | drag(policy: u16)
  | drop(policy: u16)
  | layer(kind: u8, order: i32)
  | overlay(anchor_id: u64, placement: u8)
  | modal_barrier(policy: u16)
  | unknown(kind: u16)) end

R.ui_visit_solve_node = region ui_visit_solve_node(node: @{T.UiSolveNode};
    placed(id: u64, rect: @{T.UiRect})
  | scroll(id: u64, rect: @{T.UiRect}, content_w: f32, content_h: f32)
  | text(id: u64, text_layout: @{T.UiTextLayoutRef})
  | unknown(kind: u16)) end

R.ui_visit_view_op = region ui_visit_view_op(op: @{T.UiViewOp};
    box
  | text(layout: @{T.UiTextLayoutRef})
  | paint(paint: @{T.UiPaintRef})
  | push_clip(rect: @{T.UiRect})
  | pop_clip
  | push_tx(dx: f32, dy: f32)
  | pop_tx
  | push_scroll(id: u64)
  | pop_scroll
  | hit(id: u64, role: u8, policy: u16)
  | focus(id: u64, policy: u16)
  | cursor(id: u64, cursor: u16)
  | drag_source(id: u64, policy: u16)
  | drop_target(id: u64, policy: u16)
  | drop_slot(id: u64, other_id: u64, policy: u16)
  | begin_focus_scope(id: u64, policy: u16)
  | end_focus_scope(id: u64)
  | begin_layer(id: u64, kind: u8, order: i32)
  | end_layer(id: u64)
  | overlay(id: u64, anchor_id: u64, placement: u8)
  | modal_barrier(id: u64, policy: u16)
  | unknown(kind: u16)) end

R.ui_visit_paint_program = region ui_visit_paint_program(op: @{T.UiPaintOp};
    line
  | polyline
  | polygon
  | rect
  | circle
  | arc
  | bezier
  | mesh
  | image(image: @{T.UiImageRef})
  | unknown(kind: u16)) end

R.ui_visit_raw_input = region ui_visit_raw_input(raw: @{T.UiRawInput};
    pointer_moved(x: f32, y: f32)
  | pointer_pressed(button: u16, x: f32, y: f32)
  | pointer_released(button: u16, x: f32, y: f32)
  | pointer_cancelled
  | wheel_moved(dx: f32, dy: f32, x: f32, y: f32)
  | key_pressed(key: u32, mods: u32, repeat_: u32)
  | key_released(key: u32, mods: u32)
  | text_input(text: ptr(u8), text_len: index)
  | text_editing(text: ptr(u8), text_len: index, start: u32, length: u32)
  | focus_move(direction: u32)
  | focus_lost
  | activate_focused
  | cancel_interaction
  | unknown(kind: u16)) end

R.ui_visit_event = region ui_visit_event(ev: @{T.UiEvent};
    hover_changed(id: u64)
  | pressed(id: u64, button: u16)
  | released(id: u64, button: u16)
  | activated(id: u64)
  | focus_changed(old_id: u64, new_id: u64)
  | scroll_changed(id: u64, x: f32, y: f32)
  | drag_started(id: u64, x: f32, y: f32)
  | drag_moved(id: u64, x: f32, y: f32, dx: f32, dy: f32)
  | drag_ended(id: u64, x: f32, y: f32)
  | drag_cancelled(id: u64)
  | dropped(source_id: u64, target_id: u64, slot_id: u64)
  | text_input(id: u64, text: ptr(u8), text_len: index)
  | text_editing(id: u64, text: ptr(u8), text_len: index, start: u32, length: u32)
  | text_input_without_focus(text: ptr(u8), text_len: index)
  | cancelled(id: u64)
  | capture_changed(old_id: u64, new_id: u64)
  | unknown(kind: u16)) end

R.ui_visit_key = region ui_visit_key(key: u32, mods: u32;
    activate
  | cancel
  | focus_move(direction: u32)
  | text_navigation(action: u16)
  | plain(key: u32, mods: u32)) end

R.ui_visit_value = region ui_visit_value(value: @{T.UiValueRecord};
    none
  | bool_value(value: bool)
  | i32_value(value: i32)
  | u32_value(value: u32)
  | f32_value(value: f32)
  | f64_value(value: f64)
  | id_value(value: u64)
  | ref_value(value: u32)
  | range_value(min_value: f32, max_value: f32, value: f32)
  | color_value(color: @{T.UiColor})
  | text_value(content: @{T.UiContentRef})
  | custom(kind: u16)
  | unknown(kind: u16)) end

-- -----------------------------------------------------------------------------
-- Borrow resolver protocols.
-- -----------------------------------------------------------------------------

R.ui_borrow_node = region ui_borrow_node(ui: ptr(@{T.UiKernel}), ref: @{T.UiNodeRef};
    borrowed(node: lease(ui) ptr(@{T.UiNodeRecord}))
  | missing(ref: @{T.UiNodeRef})
  | stale(ref: @{T.UiNodeRef})) end

R.ui_borrow_content = region ui_borrow_content(ui: ptr(@{T.UiKernel}), ref: @{T.UiContentRef};
    borrowed(content: lease(ui) ptr(@{T.UiContent}))
  | missing(ref: @{T.UiContentRef})
  | stale(ref: @{T.UiContentRef})) end

R.ui_borrow_text_layout = region ui_borrow_text_layout(ui: ptr(@{T.UiKernel}), ref: @{T.UiTextLayoutRef};
    borrowed(layout: lease(ui) ptr(@{T.UiTextLayout}))
  | missing(ref: @{T.UiTextLayoutRef})
  | stale(ref: @{T.UiTextLayoutRef})) end

R.ui_borrow_paint = region ui_borrow_paint(ui: ptr(@{T.UiKernel}), ref: @{T.UiPaintRef};
    borrowed(paint: lease(ui) ptr(@{T.UiPaintProgramSet}))
  | missing(ref: @{T.UiPaintRef})
  | stale(ref: @{T.UiPaintRef})) end

R.ui_borrow_image = region ui_borrow_image(ui: ptr(@{T.UiKernel}), ref: @{T.UiImageRef};
    borrowed(image: lease(ui) ptr(@{T.UiImageRecord}))
  | missing(ref: @{T.UiImageRef})
  | stale(ref: @{T.UiImageRef})) end

R.ui_borrow_font = region ui_borrow_font(ui: ptr(@{T.UiKernel}), ref: @{T.UiFontRef};
    borrowed(font: lease(ui) ptr(@{T.UiFontRecord}))
  | missing(ref: @{T.UiFontRef})
  | stale(ref: @{T.UiFontRef})) end

R.ui_borrow_value = region ui_borrow_value(ui: ptr(@{T.UiKernel}), ref: @{T.UiValueRef};
    borrowed(value: lease(ui) ptr(@{T.UiValueRecord}))
  | missing(ref: @{T.UiValueRef})
  | stale(ref: @{T.UiValueRef})) end

-- -----------------------------------------------------------------------------
-- Resource lifecycle protocols.
-- -----------------------------------------------------------------------------

R.ui_content_retain_copy = region ui_content_retain_copy(ui: ptr(@{T.UiKernel}), readonly bytes: ptr(u8), byte_len: index, encoding: u32, flags: u32;
    retained(content: owned @{T.UiContentRef})
  | bad_argument(code: i32)
  | oom(needed: index)) end

R.ui_content_publish = region ui_content_publish(ui: ptr(@{T.UiKernel}), content: owned @{T.UiContentRef};
    published(content: @{T.UiContentRef})
  | missing(content: owned @{T.UiContentRef})
  | stale(content: owned @{T.UiContentRef})) end

R.ui_content_release = region ui_content_release(ui: ptr(@{T.UiKernel}), content: owned @{T.UiContentRef};
    released
  | missing(content: owned @{T.UiContentRef})
  | stale(content: owned @{T.UiContentRef})) end

R.ui_text_layout_retain = region ui_text_layout_retain(ui: ptr(@{T.UiKernel}), readonly layout: ptr(@{T.UiTextLayout});
    retained(layout: owned @{T.UiTextLayoutRef})
  | bad_argument(code: i32)
  | oom(needed: index)) end

R.ui_text_layout_release = region ui_text_layout_release(ui: ptr(@{T.UiKernel}), layout: owned @{T.UiTextLayoutRef};
    released
  | missing(layout: owned @{T.UiTextLayoutRef})
  | stale(layout: owned @{T.UiTextLayoutRef})) end

R.ui_paint_retain = region ui_paint_retain(ui: ptr(@{T.UiKernel}), readonly ops: view(@{T.UiPaintOp}), readonly points: view(@{T.UiPaintPoint}), readonly vertices: view(@{T.UiPaintVertex}), readonly indices: view(u32);
    retained(paint: owned @{T.UiPaintRef})
  | bad_argument(code: i32)
  | oom(needed: index)) end

R.ui_paint_release = region ui_paint_release(ui: ptr(@{T.UiKernel}), paint: owned @{T.UiPaintRef};
    released
  | missing(paint: owned @{T.UiPaintRef})
  | stale(paint: owned @{T.UiPaintRef})) end

R.ui_image_register = region ui_image_register(ui: ptr(@{T.UiKernel}), host_key: u64, width: f32, height: f32, format: u32, flags: u32;
    registered(image: owned @{T.UiImageRef})
  | bad_argument(code: i32)
  | oom(needed: index)) end

R.ui_image_release = region ui_image_release(ui: ptr(@{T.UiKernel}), image: owned @{T.UiImageRef};
    released
  | missing(image: owned @{T.UiImageRef})
  | stale(image: owned @{T.UiImageRef})) end

R.ui_font_register = region ui_font_register(ui: ptr(@{T.UiKernel}), host_key: u64, family: @{T.UiContentRef}, size: f32, weight: u32, flags: u32;
    registered(font: owned @{T.UiFontRef})
  | bad_argument(code: i32)
  | missing_resource(section: u8, index_: u32)
  | oom(needed: index)) end

R.ui_font_release = region ui_font_release(ui: ptr(@{T.UiKernel}), font: owned @{T.UiFontRef};
    released
  | missing(font: owned @{T.UiFontRef})
  | stale(font: owned @{T.UiFontRef})) end

R.ui_value_retain = region ui_value_retain(ui: ptr(@{T.UiKernel}), readonly value: ptr(@{T.UiValueRecord});
    retained(value: owned @{T.UiValueRef})
  | bad_argument(code: i32)
  | oom(needed: index)) end

R.ui_value_set = region ui_value_set(ui: ptr(@{T.UiKernel}), ref: @{T.UiValueRef}, readonly value: ptr(@{T.UiValueRecord});
    set(epoch: u64)
  | missing(ref: @{T.UiValueRef})
  | stale(ref: @{T.UiValueRef})
  | bad_argument(code: i32)
  | oom(needed: index)) end

R.ui_value_release = region ui_value_release(ui: ptr(@{T.UiKernel}), value: owned @{T.UiValueRef};
    released
  | missing(value: owned @{T.UiValueRef})
  | stale(value: owned @{T.UiValueRef})) end

-- -----------------------------------------------------------------------------
-- Public C ABI seals.  These are product-to-product.  They convert region
-- protocols to UiStatus exactly once and do not duplicate region logic.
-- -----------------------------------------------------------------------------

F.mlui_abi_version = func mlui_abi_version(): u32 end

F.mlui_kernel_init = func mlui_kernel_init(out: ptr(ptr(@{T.UiKernel}))): @{T.UiStatus} end

F.mlui_kernel_init_ex = func mlui_kernel_init_ex(readonly config: ptr(@{T.UiConfig}), out: ptr(ptr(@{T.UiKernel}))): @{T.UiStatus} end

F.mlui_kernel_close = func mlui_kernel_close(ui: ptr(@{T.UiKernel})): @{T.UiStatus} end

F.mlui_kernel_reset_frame = func mlui_kernel_reset_frame(ui: ptr(@{T.UiKernel})): @{T.UiStatus} end

F.mlui_validate_program = func mlui_validate_program(ui: ptr(@{T.UiKernel}), readonly program: ptr(@{T.UiProgram})): @{T.UiStatus} end

F.mlui_load_program = func mlui_load_program(ui: ptr(@{T.UiKernel}), readonly program: ptr(@{T.UiProgram}), out_root: ptr(@{T.UiNodeRef})): @{T.UiStatus} end

F.mlui_load_llpv_program = func mlui_load_llpv_program(ui: ptr(@{T.UiKernel}), readonly bytes: ptr(u8), byte_len: index, out_root: ptr(@{T.UiNodeRef})): @{T.UiStatus} end

F.mlui_import_auth_buffer = func mlui_import_auth_buffer(ui: ptr(@{T.UiKernel}), readonly nodes: ptr(@{T.UiAuthNode}), node_count: index, readonly children: ptr(u32), child_count: index, out_root: ptr(@{T.UiNodeRef})): @{T.UiStatus} end

F.mlui_lower_solve_render = func mlui_lower_solve_render(ui: ptr(@{T.UiKernel}), root: @{T.UiNodeRef}, width: f32, height: f32): @{T.UiStatus} end

F.mlui_frame = func mlui_frame(ui: ptr(@{T.UiKernel}), root: @{T.UiNodeRef}, width: f32, height: f32, readonly raw: ptr(@{T.UiRawInputBuffer})): @{T.UiStatus} end

F.mlui_runtime_report = func mlui_runtime_report(ui: ptr(@{T.UiKernel})): @{T.UiStatus} end

F.mlui_interact_step = func mlui_interact_step(ui: ptr(@{T.UiKernel}), readonly raw: ptr(@{T.UiRawInputBuffer})): @{T.UiStatus} end

F.mlui_view_ops = func mlui_view_ops(ui: ptr(@{T.UiKernel}), out_ops: ptr(ptr(@{T.UiViewOp})), out_count: ptr(index)): @{T.UiStatus} end

F.mlui_events = func mlui_events(ui: ptr(@{T.UiKernel}), out_events: ptr(ptr(@{T.UiEvent})), out_count: ptr(index)): @{T.UiStatus} end

F.mlui_report_get = func mlui_report_get(ui: ptr(@{T.UiKernel}), out_report: ptr(ptr(@{T.UiReport}))): @{T.UiStatus} end

F.mlui_clear_events = func mlui_clear_events(ui: ptr(@{T.UiKernel})): @{T.UiStatus} end

F.mlui_content_retain_copy = func mlui_content_retain_copy(ui: ptr(@{T.UiKernel}), readonly bytes: ptr(u8), byte_len: index, encoding: u32, flags: u32, out: ptr(@{T.UiContentRef})): @{T.UiStatus} end

F.mlui_content_release = func mlui_content_release(ui: ptr(@{T.UiKernel}), ref: @{T.UiContentRef}): @{T.UiStatus} end

F.mlui_paint_retain = func mlui_paint_retain(ui: ptr(@{T.UiKernel}), readonly ops: ptr(@{T.UiPaintOp}), op_count: index, readonly points: ptr(@{T.UiPaintPoint}), point_count: index, out: ptr(@{T.UiPaintRef})): @{T.UiStatus} end

F.mlui_paint_release = func mlui_paint_release(ui: ptr(@{T.UiKernel}), ref: @{T.UiPaintRef}): @{T.UiStatus} end

F.mlui_image_register = func mlui_image_register(ui: ptr(@{T.UiKernel}), host_key: u64, width: f32, height: f32, format: u32, out: ptr(@{T.UiImageRef})): @{T.UiStatus} end

F.mlui_image_release = func mlui_image_release(ui: ptr(@{T.UiKernel}), ref: @{T.UiImageRef}): @{T.UiStatus} end

F.mlui_font_register = func mlui_font_register(ui: ptr(@{T.UiKernel}), host_key: u64, family: @{T.UiContentRef}, size: f32, weight: u32, flags: u32, out: ptr(@{T.UiFontRef})): @{T.UiStatus} end

F.mlui_font_release = func mlui_font_release(ui: ptr(@{T.UiKernel}), ref: @{T.UiFontRef}): @{T.UiStatus} end

F.mlui_value_set = func mlui_value_set(ui: ptr(@{T.UiKernel}), ref: @{T.UiValueRef}, readonly value: ptr(@{T.UiValueRecord})): @{T.UiStatus} end

F.mlui_value_retain = func mlui_value_retain(ui: ptr(@{T.UiKernel}), readonly value: ptr(@{T.UiValueRecord}), out: ptr(@{T.UiValueRef})): @{T.UiStatus} end

F.mlui_value_release = func mlui_value_release(ui: ptr(@{T.UiKernel}), ref: @{T.UiValueRef}): @{T.UiStatus} end

-- WASM ABI seals: uint32 status code / offset protocol for wasm32 linear memory.
F.mlui_wasm_abi_version = func mlui_wasm_abi_version(): u32 end
F.mlui_wasm_kernel_init = func mlui_wasm_kernel_init(config_offset: u32, out_kernel_offset: u32): u32 end
F.mlui_wasm_kernel_close = func mlui_wasm_kernel_close(kernel: u32): u32 end
F.mlui_wasm_load_program = func mlui_wasm_load_program(kernel: u32, program_offset: u32, out_root_offset: u32): u32 end
F.mlui_wasm_load_llpv_program = func mlui_wasm_load_llpv_program(kernel: u32, bytes_offset: u32, byte_len: u32, out_root_offset: u32): u32 end
F.mlui_wasm_frame = func mlui_wasm_frame(kernel: u32, root: u32, width: f32, height: f32, raw_offset: u32, raw_count: u32): u32 end
F.mlui_wasm_view_ops = func mlui_wasm_view_ops(kernel: u32, out_offset_count: u32): u32 end
F.mlui_wasm_events = func mlui_wasm_events(kernel: u32, out_offset_count: u32): u32 end
F.mlui_wasm_report_get = func mlui_wasm_report_get(kernel: u32, out_offset: u32): u32 end

return {
    T = T,
    R = R,
    F = F,
}
