-- mlui_header.mlua
-- Public Moonlift declaration header for the MLUI LLPVM VM stack.
--
-- This file is intentionally declaration-shaped: it names public products,
-- handles, protocol-rich regions, and sealed ABI function headers.  Bodies
-- belong in the machine implementation files: mlui_memory.mlua,
-- mlui_program_validate.mlua, mlui_scene_lower.mlua, mlui_abi.mlua, etc.
--
-- Source of semantic truth: mlui_stack.mlua.
-- Projection rule: generated C/WASM rows and constants must be generated from
-- or mechanically checked against mlui_stack.mlua and this header.

local moon = require "moonlift"

local T = {}
local R = {}
local F = {}

-- -----------------------------------------------------------------------------
-- v1 constants.  These are Lua constants for generators/tests; Moonlift object
-- code should use the corresponding scalar fields and protocol exits.
-- -----------------------------------------------------------------------------

T.MLUI_ABI_VERSION = 1
T.MLUI_MAGIC_U32 = 0x49554c4d       -- 'M''L''U''I' little-endian
T.MLUI_LLPV_MAGIC_U32 = 0x56504c4c  -- 'L''L''P''V' little-endian

T.StatusCode = {
    OK                  = 0,
    OOM                 = 1,
    DUPLICATE_ID        = 2,
    INVALID_ID          = 3,
    INVALID_CHILD       = 4,
    UNSUPPORTED_NODE    = 5,
    MISSING_NODE        = 6,
    MISSING_TEXT        = 7,
    TEXT_BACKEND_ERROR  = 8,
    DECOR_MISMATCH      = 9,
    MALFORMED_OP        = 10,
    STACK_UNBALANCED    = 11,
    STALE_FOCUS         = 12,
    STALE_CAPTURE       = 13,
    MISSING_SCROLL      = 14,
    INVALID_HEADER      = 15,
    INVALID_SECTION     = 16,
    INVALID_OPCODE      = 17,
    INVALID_RANGE       = 18,
    INVALID_ARITY       = 19,
    MISSING_RESOURCE    = 20,
    UNSUPPORTED_FEATURE = 21,
    STALE_REF           = 22,
    BUSY                = 23,
    BAD_ARGUMENT        = 24,
    BACKEND_ERROR       = 25,
}

T.RootKind = {
    NONE    = 0,
    AUTH    = 1,
    COMPOSE = 2,
    LLPV    = 3,
}

T.Axis = {
    NONE = 0,
    X    = 1,
    Y    = 2,
    BOTH = 3,
}

T.Direction = {
    NONE    = 0,
    LEFT    = 1,
    RIGHT   = 2,
    UP      = 3,
    DOWN    = 4,
    NEXT    = 5,
    PREV    = 6,
    INWARD  = 7,
    OUTWARD = 8,
}

T.InputRole = {
    NONE       = 0,
    BUTTON     = 1,
    CHECKBOX   = 2,
    SLIDER     = 3,
    TEXT_FIELD = 4,
    MENU_ITEM  = 5,
    TAB        = 6,
    CANVAS     = 7,
    CUSTOM     = 255,
}

T.StateMask = {
    HOVERED       = 0x00000001,
    PRESSED       = 0x00000002,
    ACTIVE        = 0x00000004,
    FOCUSED       = 0x00000008,
    DISABLED      = 0x00000010,
    SELECTED      = 0x00000020,
    DRAGGING      = 0x00000040,
    DROP_HOVERED  = 0x00000080,
    EDITING       = 0x00000100,
    INVALID       = 0x00000200,
    MODAL_ACTIVE  = 0x00000400,
}

T.AuthKind = {
    EMPTY         = 0,
    FRAGMENT      = 1,
    BOX           = 2,
    TEXT          = 3,
    TEXT_INLINE   = 4,
    TEXT_REF      = 5,
    PAINT         = 6,
    CANVAS        = 7,
    IMAGE         = 8,
    SCROLL        = 9,
    INPUT_SURFACE = 10,
    DRAG_SOURCE   = 11,
    DROP_TARGET   = 12,
    FOCUS_SCOPE   = 13,
    LAYER         = 14,
    OVERLAY       = 15,
    MODAL         = 16,
    TEXT_FIELD    = 17,
    SLOT          = 18,
}

T.ComposeKind = {
    PANEL        = 1,
    SCROLL_PANEL = 2,
    HSPLIT       = 3,
    VSPLIT       = 4,
    WORKBENCH    = 5,
}

T.LayoutKind = {
    EMPTY         = 0,
    FRAGMENT      = 1,
    FLOW          = 2,
    FLEX_ROW      = 3,
    FLEX_COLUMN   = 4,
    GRID          = 5,
    TEXT          = 6,
    TEXT_REF      = 7,
    PAINT         = 8,
    CANVAS        = 9,
    IMAGE         = 10,
    SCROLL        = 11,
    INPUT_SURFACE = 12,
    DRAG_SOURCE   = 13,
    DROP_TARGET   = 14,
    FOCUS_SCOPE   = 15,
    LAYER         = 16,
    OVERLAY       = 17,
    MODAL         = 18,
    TEXT_FIELD    = 19,
}

T.DecorKind = {
    NONE          = 0,
    BOX           = 1,
    TEXT          = 2,
    PAINT         = 3,
    IMAGE         = 4,
    CURSOR        = 5,
    HIT           = 6,
    FOCUS         = 7,
    DRAG          = 8,
    DROP          = 9,
    LAYER         = 10,
    OVERLAY       = 11,
    MODAL_BARRIER = 12,
}

T.ViewKind = {
    BOX               = 1,
    TEXT              = 2,
    PAINT             = 3,
    PUSH_CLIP_RECT    = 4,
    POP_CLIP          = 5,
    PUSH_TX           = 6,
    POP_TX            = 7,
    PUSH_SCROLL       = 8,
    POP_SCROLL        = 9,
    HIT               = 10,
    FOCUS             = 11,
    CURSOR            = 12,
    DRAG_SOURCE       = 13,
    DROP_TARGET       = 14,
    DROP_SLOT         = 15,
    BEGIN_FOCUS_SCOPE = 16,
    END_FOCUS_SCOPE   = 17,
    BEGIN_LAYER       = 18,
    END_LAYER         = 19,
    OVERLAY           = 20,
    MODAL_BARRIER     = 21,
}

T.RawInputKind = {
    POINTER_MOVED      = 1,
    POINTER_PRESSED    = 2,
    POINTER_RELEASED   = 3,
    POINTER_CANCELLED  = 4,
    WHEEL_MOVED        = 5,
    KEY_PRESSED        = 6,
    KEY_RELEASED       = 7,
    TEXT_INPUT         = 8,
    TEXT_EDITING       = 9,
    FOCUS_MOVE         = 10,
    FOCUS_LOST         = 11,
    ACTIVATE_FOCUSED   = 12,
    CANCEL_INTERACTION = 13,
}

T.EventKind = {
    HOVER_CHANGED       = 1,
    PRESSED             = 2,
    RELEASED            = 3,
    ACTIVATED           = 4,
    FOCUS_CHANGED       = 5,
    SCROLL_CHANGED      = 6,
    DRAG_STARTED        = 7,
    DRAG_MOVED          = 8,
    DRAG_ENDED          = 9,
    DRAG_CANCELLED      = 10,
    DROPPED             = 11,
    TEXT_INPUT          = 12,
    TEXT_EDITING        = 13,
    TEXT_INPUT_NO_FOCUS = 14,
    CANCELLED           = 15,
    CAPTURE_CHANGED     = 16,
}

T.PaintKind = {
    LINE     = 1,
    POLYLINE = 2,
    POLYGON  = 3,
    RECT     = 4,
    CIRCLE   = 5,
    ARC      = 6,
    BEZIER   = 7,
    MESH     = 8,
    IMAGE    = 9,
}

T.ValueKind = {
    NONE   = 0,
    BOOL   = 1,
    I32    = 2,
    U32    = 3,
    F32    = 4,
    F64    = 5,
    ID     = 6,
    REF    = 7,
    RANGE  = 8,
    COLOR  = 9,
    TEXT   = 10,
    CUSTOM = 255,
}

-- -----------------------------------------------------------------------------
-- Scalar aliases for hosted Lua generators.
-- -----------------------------------------------------------------------------

T.UiId = moon.u64
T.UiRefBits = moon.u32
T.UiEpoch = moon.u64
T.UiKind = moon.u16
T.UiFlags = moon.u32
T.UiIndex32 = moon.u32
T.UiScalar = moon.f32

-- -----------------------------------------------------------------------------
-- Handles.  C encodes these as uint32_t in the v1 fast-row profile.
-- -----------------------------------------------------------------------------

T.UiKernelRef = handle UiKernelRef : u32 invalid 0
    domain UiKernelStore
    target UiKernel
end

T.UiNodeRef = handle UiNodeRef : u32 invalid 0
    domain UiNodeStore
    target UiNodeRecord
end

T.UiContentRef = handle UiContentRef : u32 invalid 0
    domain UiContentStore
    target UiContent
end

T.UiTextLayoutRef = handle UiTextLayoutRef : u32 invalid 0
    domain UiTextLayoutStore
    target UiTextLayout
end

T.UiPaintRef = handle UiPaintRef : u32 invalid 0
    domain UiPaintStore
    target UiPaintProgramSet
end

T.UiImageRef = handle UiImageRef : u32 invalid 0
    domain UiImageStore
    target UiImageRecord
end

T.UiFontRef = handle UiFontRef : u32 invalid 0
    domain UiFontStore
    target UiFontRecord
end

T.UiValueRef = handle UiValueRef : u32 invalid 0
    domain UiValueStore
    target UiValueRecord
end

T.UiThemeRef = handle UiThemeRef : u32 invalid 0
    domain UiThemeStore
    target UiTheme
end

T.UiScrollRef = handle UiScrollRef : u32 invalid 0
    domain UiScrollStore
    target UiScrollState
end

-- -----------------------------------------------------------------------------
-- Common products.
-- -----------------------------------------------------------------------------

T.UiStatus = struct UiStatus
    code: i32,
    detail: i32,
    at: index,
    needed: index
end

T.UiVec2 = struct UiVec2
    x: f32,
    y: f32
end

T.UiRect = struct UiRect
    x: f32,
    y: f32,
    w: f32,
    h: f32
end

T.UiInsets = struct UiInsets
    left: f32,
    top: f32,
    right: f32,
    bottom: f32
end

T.UiColor = struct UiColor
    r: f32,
    g: f32,
    b: f32,
    a: f32
end

T.UiRange = struct UiRange
    first: u32,
    count: u32
end

T.UiSize = struct UiSize
    w: f32,
    h: f32
end

T.UiViewport = struct UiViewport
    x: f32,
    y: f32,
    w: f32,
    h: f32,
    device_scale: f32
end

T.UiEpochs = struct UiEpochs
    program_epoch: u64,
    content_epoch: u64,
    paint_epoch: u64,
    image_epoch: u64,
    font_epoch: u64,
    value_epoch: u64,
    theme_epoch: u64,
    text_layout_epoch: u64,
    scene_epoch: u64,
    measure_epoch: u64,
    solve_epoch: u64,
    view_epoch: u64,
    report_epoch: u64,
    model_epoch: u64,
    scroll_epoch: u64
end

