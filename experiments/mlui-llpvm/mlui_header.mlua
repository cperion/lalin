    radius_range: @{T.UiRange},
    border_range: @{T.UiRange},
    opacity_range: @{T.UiRange}
end

-- -----------------------------------------------------------------------------
-- Program bytecode / fast-row projection.
-- -----------------------------------------------------------------------------

T.UiAuthNode = struct UiAuthNode
    kind: u16,
    id: u64,
    parent: u32,
    first_child: u32,
    child_count: u32,
    first_style: u32,
    style_count: u32,
    first_paint: u32,
    paint_count: u32,
    content_ref: @{T.UiContentRef},
    text_layout_ref: @{T.UiTextLayoutRef},
    image_ref: @{T.UiImageRef},
    font_ref: @{T.UiFontRef},
    value_ref: @{T.UiValueRef},
    other_id: u64,
    axis: u8,
    role: u8,
    policy: u16,
    state_mask: u32,
    flags: u32
end

T.UiComposeNode = struct UiComposeNode
    kind: u16,
    id: u64,
    first_child: u32,
    child_count: u32,
    first_style: u32,
    style_count: u32,
    first_weight: u32,
    weight_count: u32,
    axis: u8,
    flags: u32
end

T.UiProgramHeader = struct UiProgramHeader
    magic: u32,
    abi_version: u32,
    flags: u32,
    endian: u8,
    pointer_size: u8,
    root_kind: u8,
    reserved0: u8,
    root_index: u32
end

T.UiPaintPoint = struct UiPaintPoint
    x: f32,
    y: f32
end

T.UiPaintVertex = struct UiPaintVertex
    x: f32,
    y: f32,
    u: f32,
    v: f32,
    color: @{T.UiColor}
end

T.UiPaintOp = struct UiPaintOp
    kind: u16,
    stroke_join_cap: u16,
    flags: u32,
    first: u32,
    count: u32,
    rect: @{T.UiRect},
    fill: @{T.UiColor},
    stroke: @{T.UiColor},
    stroke_width: f32,
    radius: f32,
    image_ref: @{T.UiImageRef}
end

T.UiProgram = struct UiProgram
    header: @{T.UiProgramHeader},
    auth_nodes: ptr(@{T.UiAuthNode}),
    auth_count: index,
    compose_nodes: ptr(@{T.UiComposeNode}),
    compose_count: index,
    children: ptr(u32),
    child_count: index,
    style_tokens: ptr(@{T.UiStyleToken}),
    style_token_count: index,
    style_conds: ptr(@{T.UiStyleCond}),
    style_cond_count: index,
    style_atoms: ptr(@{T.UiStyleAtom}),
    style_atom_count: index,
    tracks: ptr(@{T.UiTrack}),
    track_count: index,
    paint_ops: ptr(@{T.UiPaintOp}),
    paint_op_count: index,
    paint_points: ptr(@{T.UiPaintPoint}),
    paint_point_count: index,
    paint_vertices: ptr(@{T.UiPaintVertex}),
    paint_vertex_count: index,
    paint_indices: ptr(u32),
    paint_index_count: index,
    feature_flags: u64
end

T.UiAuthBuffer = struct UiAuthBuffer
    nodes: ptr(@{T.UiAuthNode}),
    count: index,
    cap: index,
    children: ptr(u32),
    child_count: index,
    child_cap: index,
    epoch: u64
end

