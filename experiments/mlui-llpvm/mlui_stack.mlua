    event_kind = {
        HOVER_CHANGED = 1,
        PRESSED = 2,
        RELEASED = 3,
        ACTIVATED = 4,
        FOCUS_CHANGED = 5,
        SCROLL_CHANGED = 6,
        DRAG_STARTED = 7,
        DRAG_MOVED = 8,
        DRAG_ENDED = 9,
        DRAG_CANCELLED = 10,
        DROPPED = 11,
        TEXT_INPUT = 12,
        TEXT_EDITING = 13,
        TEXT_INPUT_NO_FOCUS = 14,
        CANCELLED = 15,
        CAPTURE_CHANGED = 16,
    },
}

-- Auth arity table used by validators and C/WASM builder generators.
M.auth_arity = {
    EMPTY = { min = 0, max = 0 },
    FRAGMENT = { min = 0, max = false },
    BOX = { min = 0, max = false },
    TEXT = { min = 0, max = 0 },
    TEXT_INLINE = { min = 0, max = 0 },
    TEXT_REF = { min = 0, max = 0 },
    PAINT = { min = 0, max = 0 },
    CANVAS = { min = 0, max = 0 },
    IMAGE = { min = 0, max = 0 },
    SCROLL = { min = 1, max = 1 },
    INPUT_SURFACE = { min = 1, max = 1 },
    DRAG_SOURCE = { min = 1, max = 1 },
    DROP_TARGET = { min = 1, max = 1 },
    FOCUS_SCOPE = { min = 0, max = false },
    LAYER = { min = 1, max = 1 },
    OVERLAY = { min = 1, max = 1 },
    MODAL = { min = 1, max = 1 },
    TEXT_FIELD = { min = 0, max = 0 },
    SLOT = { min = 0, max = 1 },
}

M.row_profiles = {
    auth_node = {
        c_name = "mlui_auth_node",
        kind_enum = "auth_kind",
        fields = {
            { "kind", "uint16_t" },
            { "id", "mlui_id" },
            { "parent", "uint32_t" },
            { "first_child", "uint32_t" },
            { "child_count", "uint32_t" },
            { "first_style", "uint32_t" },
            { "style_count", "uint32_t" },
            { "first_paint", "uint32_t" },
            { "paint_count", "uint32_t" },
            { "content_ref", "mlui_content_ref" },
            { "text_layout_ref", "mlui_text_layout_ref" },
            { "image_ref", "mlui_image_ref" },
            { "font_ref", "mlui_font_ref" },
            { "value_ref", "mlui_value_ref" },
            { "other_id", "mlui_id" },
            { "axis", "uint8_t" },
            { "role", "uint8_t" },
            { "policy", "uint16_t" },
            { "state_mask", "uint32_t" },
            { "flags", "uint32_t" },
        },
    },
    compose_node = {
        c_name = "mlui_compose_node",
        kind_enum = "compose_kind",
        fields = {
            { "kind", "uint16_t" },
            { "id", "mlui_id" },
            { "first_child", "uint32_t" },
            { "child_count", "uint32_t" },
            { "first_style", "uint32_t" },
            { "style_count", "uint32_t" },
            { "first_weight", "uint32_t" },
            { "weight_count", "uint32_t" },
            { "axis", "uint8_t" },
            { "flags", "uint32_t" },
        },
    },
    view_op = {
        c_name = "mlui_view_op",
        kind_enum = "view_kind",
        fields = {
            { "kind", "uint16_t" },
            { "axis_role_policy_hi", "uint16_t" },
            { "flags", "uint32_t" },
            { "id", "mlui_id" },
            { "other_id", "mlui_id" },
            { "rect", "mlui_rect" },
            { "first", "uint32_t" },
            { "count", "uint32_t" },
            { "content_ref", "mlui_content_ref" },
            { "text_layout_ref", "mlui_text_layout_ref" },
            { "paint_ref", "mlui_paint_ref" },
            { "image_ref", "mlui_image_ref" },
            { "order", "int32_t" },
            { "dx", "float" },
            { "dy", "float" },
            { "content_w", "float" },
            { "content_h", "float" },
        },
    },
    raw_input = {
        c_name = "mlui_raw_input",
        kind_enum = "raw_input_kind",
        borrowed_text = true,
    },
    event = {
        c_name = "mlui_event",
        kind_enum = "event_kind",
        borrowed_text_until = "next mlui_clear_events/mlui_frame/reset/close",
    },
}

M.validation = {
    program = {
        "non_null_program",
        "magic",
        "abi_version",
        "endian",
        "pointer_size",
        "root_kind",
        "root_index",
        "section_pointer_count_pairs",
        "auth_kind_range",
        "compose_kind_range",
        "child_ranges",
        "auth_arity",
        "style_ranges",
        "track_ranges",
        "paint_ranges",
        "required_resource_refs",
        "duplicate_nonzero_ids",
        "feature_flags",
    },
    view_stream = {
        "kind_range",
        "transform_stack_balanced",
        "clip_stack_balanced",
        "scroll_stack_balanced",
        "focus_scope_stack_balanced",
        "layer_stack_balanced",
    },
    text = {
        "borrowed_input_text_dispatch_only",
        "durable_text_copied_into_content_store",
        "render_consumes_text_layout_ref_only",
    },
}

M.abi = {
    header = "mlui_header.mlua",
    c_header = "mlui_c_api.h",
    c_prefix = "mlui_",
    wasm_prefix = "mlui_wasm_",
    functions = {
        "mlui_abi_version",
        "mlui_kernel_init",
        "mlui_kernel_init_ex",
        "mlui_kernel_close",
        "mlui_kernel_reset_frame",
        "mlui_validate_program",
        "mlui_load_program",
        "mlui_load_llpv_program",
        "mlui_import_auth_buffer",
        "mlui_lower_solve_render",
        "mlui_frame",
        "mlui_runtime_report",
        "mlui_interact_step",
        "mlui_view_ops",
        "mlui_events",
        "mlui_report_get",
        "mlui_clear_events",
        "mlui_content_retain_copy",
        "mlui_content_release",
        "mlui_paint_retain",
        "mlui_paint_release",
        "mlui_image_register",
        "mlui_image_release",
        "mlui_font_register",
        "mlui_font_release",
        "mlui_value_set",
        "mlui_value_retain",
        "mlui_value_release",
    },
    wasm_functions = {
        "mlui_wasm_abi_version",
        "mlui_wasm_kernel_init",
        "mlui_wasm_kernel_close",
        "mlui_wasm_load_program",
        "mlui_wasm_load_llpv_program",
        "mlui_wasm_frame",
        "mlui_wasm_view_ops",
        "mlui_wasm_events",
        "mlui_wasm_report_get",
    },
}

function M.program(roots)
    return M.vm.program(roots)
end

function M.bytecode(roots)
    return M.program(roots):bytecode()
end

return M
