M.ReportFact.ReportHeader = { epoch = T.Epoch, viewport = T.Rect, pointer = T.Vec2, hover_id = T.Id, cursor_id = T.Id, cursor = ll.u16, scroll_target_id = T.Id, modal_depth = ll.u32, flags = ll.u32 }

