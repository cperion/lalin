M.InputRaw.FocusLost = {}
M.InputRaw.ActivateFocused = {}
M.InputRaw.CancelInteraction = {}

M.ModelState = M.Model "State"
M.ModelState.Model = {
    epoch = T.Epoch,
    pointer = T.Vec2,
    hover_id = T.Id,
    pressed_id = T.Id,
    capture_id = T.Id,
    focus_id = T.Id,
    active_id = T.Id,
    drag_id = T.Id,
    drag_state = ll.u8,
    drag_start = T.Vec2,
    modal_scope_id = T.Id,
    focus_scope_id = T.Id,
    scroll_epoch = T.Epoch,
}
M.ModelState.Scroll = { id = T.Id, x = ll.f32, y = ll.f32, content_w = ll.f32, content_h = ll.f32, viewport_w = ll.f32, viewport_h = ll.f32, epoch = T.Epoch }
M.ModelState.TextEdit = { id = T.Id, cursor = ll.u32, selection_start = ll.u32, selection_end = ll.u32, composing_start = ll.u32, composing_len = ll.u32, flags = ll.u32, epoch = T.Epoch }

M.EventEvent = M.Event "Event"
M.EventEvent.HoverChanged = { id = T.Id, hovered = ll.bool }
M.EventEvent.Pressed = { id = T.Id, button = ll.u16 }
M.EventEvent.Released = { id = T.Id, button = ll.u16 }
M.EventEvent.Activated = { id = T.Id }
M.EventEvent.FocusChanged = { old_id = T.Id, new_id = T.Id }
M.EventEvent.ScrollChanged = { id = T.Id, x = ll.f32, y = ll.f32 }
M.EventEvent.DragStarted = { id = T.Id, x = ll.f32, y = ll.f32 }
M.EventEvent.DragMoved = { id = T.Id, x = ll.f32, y = ll.f32, dx = ll.f32, dy = ll.f32 }
M.EventEvent.DragEnded = { id = T.Id, x = ll.f32, y = ll.f32 }
M.EventEvent.DragCancelled = { id = T.Id }
M.EventEvent.Dropped = { source_id = T.Id, target_id = T.Id, slot_id = T.Id }
M.EventEvent.TextInput = { id = T.Id, content_ref = T.Ref }
M.EventEvent.TextEditing = { id = T.Id, content_ref = T.Ref, start = ll.u32, length = ll.u32 }
M.EventEvent.TextInputWithoutFocus = { content_ref = T.Ref }
M.EventEvent.Cancelled = { id = T.Id }
M.EventEvent.CaptureChanged = { old_id = T.Id, new_id = T.Id }

-- -----------------------------------------------------------------------------
-- Worlds.
-- -----------------------------------------------------------------------------

M.worlds = {}
M.worlds.env           = M.Env:world "env"
M.worlds.theme         = M.Theme:world "theme"
M.worlds.style         = M.Style:world "style"
M.worlds.style_resolved = M.Style:world "style_resolved"
M.worlds.resource      = M.Resource:world "resource"
M.worlds.compose       = M.Compose:world "compose"
M.worlds.auth          = M.Auth:world "auth"
M.worlds.auth_checked  = M.Auth:world "auth_checked"
M.worlds.imported      = M.Imported:world "imported"
M.worlds.scene         = M.Scene:world "scene"
M.worlds.measure       = M.Measure:world "measure"
M.worlds.solve         = M.Solve:world "solve"
M.worlds.view          = M.View:world "view"
M.worlds.report        = M.Report:world "report"
M.worlds.input         = M.Input:world "input"
M.worlds.model         = M.Model:world "model"
M.worlds.event         = M.Event:world "event"

-- -----------------------------------------------------------------------------
-- Machines and cached phases.  This is where MLUI becomes naturally retained:
-- app/frontends may rebuild streams immediately; LLPVM phase keys reuse stable
-- phase products when streams, explicit args, and resource generations match.
-- -----------------------------------------------------------------------------

M.machines = {}
M.phases = {}

M.machines.expand_compose = M.vm.machine "mlui_expand_compose" {
    from = M.worlds.compose,
    to = M.worlds.auth,
    entry = "ui_expand_compose",
}

M.machines.validate_auth = M.vm.machine "mlui_validate_auth" {
    from = M.worlds.auth,
    to = M.worlds.auth_checked,
    entry = "ui_validate_program",
}

M.machines.import_auth = M.vm.machine "mlui_import_auth" {
    from = M.worlds.auth_checked,
    to = M.worlds.imported,
    entry = "ui_import_auth",
}

M.machines.resolve_style = M.vm.machine "mlui_resolve_style" {
    from = M.worlds.style,
    to = M.worlds.style_resolved,
    entry = "ui_resolve_style",
}

M.machines.lower_scene = M.vm.machine "mlui_lower_scene" {
    from = M.worlds.imported,
    to = M.worlds.scene,
    entry = "ui_lower_scene",
}

M.machines.measure_scene = M.vm.machine "mlui_measure_scene" {
    from = M.worlds.scene,
    to = M.worlds.measure,
    entry = "ui_measure_scene",
}

M.machines.solve_scene = M.vm.machine "mlui_solve_scene" {
    from = M.worlds.measure,
    to = M.worlds.solve,
    entry = "ui_solve_scene",
}

M.machines.render_view = M.vm.machine "mlui_render_view" {
    from = M.worlds.solve,
    to = M.worlds.view,
    entry = "ui_render_ops",
}

M.machines.build_report = M.vm.machine "mlui_build_report" {
    from = M.worlds.view,
    to = M.worlds.report,
    entry = "ui_runtime_report",
}

M.machines.interact_step = M.vm.machine "mlui_interact_step" {
    from = M.worlds.input,
    to = M.worlds.event,
    entry = "ui_interact_step",
}

M.phases.expand_compose = M.vm.phase "mlui_expand_compose" {
    from = M.worlds.compose,
    to = M.worlds.auth,
    machine = M.machines.expand_compose,
    cache = "full",
}

M.phases.validate_auth = M.vm.phase "mlui_validate_auth" {
    from = M.worlds.auth,
    to = M.worlds.auth_checked,
    machine = M.machines.validate_auth,
    cache = "record",
}

M.phases.import_auth = M.vm.phase "mlui_import_auth" {
    from = M.worlds.auth_checked,
    to = M.worlds.imported,
    machine = M.machines.import_auth,
    cache = "full",
}

M.phases.resolve_style = M.vm.phase "mlui_resolve_style" {
    from = M.worlds.style,
    to = M.worlds.style_resolved,
    machine = M.machines.resolve_style,
    cache = "full",
}

M.phases.lower_scene = M.vm.phase "mlui_lower_scene" {
    from = M.worlds.imported,
    to = M.worlds.scene,
    machine = M.machines.lower_scene,
    cache = "full",
}

M.phases.measure_scene = M.vm.phase "mlui_measure_scene" {
    from = M.worlds.scene,
    to = M.worlds.measure,
    machine = M.machines.measure_scene,
    cache = "full",
}

M.phases.solve_scene = M.vm.phase "mlui_solve_scene" {
    from = M.worlds.measure,
    to = M.worlds.solve,
    machine = M.machines.solve_scene,
    cache = "full",
}

M.phases.render_view = M.vm.phase "mlui_render_view" {
    from = M.worlds.solve,
    to = M.worlds.view,
    machine = M.machines.render_view,
    cache = "record",
}

M.phases.build_report = M.vm.phase "mlui_build_report" {
    from = M.worlds.view,
    to = M.worlds.report,
    machine = M.machines.build_report,
    cache = "record",
}

M.phases.interact_step = M.vm.phase "mlui_interact_step" {
    from = M.worlds.input,
    to = M.worlds.event,
    machine = M.machines.interact_step,
    cache = nil,
}

M.phase_order = {
    "expand_compose",
    "validate_auth",
    "import_auth",
    "resolve_style",
    "lower_scene",
    "measure_scene",
    "solve_scene",
    "render_view",
    "build_report",
    "interact_step",
}

M.phase_args = {
    expand_compose = {},
    validate_auth = { "resource_args" },
    import_auth = { "resource_args" },
    resolve_style = { "env_args", "theme_args", "interaction_args" },
    lower_scene = { "env_args", "theme_args", "resource_args", "interaction_args" },
    measure_scene = { "env_args", "resource_args" },
    solve_scene = { "solve_args" },
    render_view = { "render_args" },
    build_report = { "report_args" },
    interact_step = { "env_args", "interaction_args" },
}

