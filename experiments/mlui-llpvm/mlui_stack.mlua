M.SceneDecor.Paint = { id = T.Id, paint_ref = T.Ref, paint_range = T.Range }
M.SceneDecor.Image = { id = T.Id, image_ref = T.Ref }
M.SceneDecor.Cursor = { id = T.Id, cursor = ll.u16 }
M.SceneDecor.Hit = { id = T.Id, role = T.Role, policy = T.Policy }
M.SceneDecor.Focus = { id = T.Id, policy = T.Policy }
M.SceneDecor.Drag = { id = T.Id, policy = T.Policy }
