-- mlui_stack.mlua
-- Canonical LLPVM stack declaration for MLUI.
--
-- This file is the semantic source of truth.  It declares the MLUI operation
-- languages, typed constructors, worlds, machines, phases, cache policy, row
-- projections, ABI names, and validation tables.  mlui_header.mlua,
-- mlui_bytecode.md, mlui_c_api.h, and WASM constants should be generated from or
-- mechanically checked against this file.

local ll = require "llpvm"

local M = {}

M.vm = ll.vm {
    cache_bytes = 64 * 1024,
}

local function struct(name, fields)
    return ll.struct(name)(fields)
end

local function field(name, ty)
    return ll.field(name, ty)
end

-- -----------------------------------------------------------------------------
-- Shared LLPVM type products.
-- -----------------------------------------------------------------------------

M.T = {}
local T = M.T

T.Id      = ll.u64
T.Ref     = ll.u32
T.Epoch   = ll.u64
T.Kind    = ll.u16
T.Flags   = ll.u32
T.Index32 = ll.u32
T.Axis    = ll.u8
T.Role    = ll.u8
T.Policy  = ll.u16

T.Vec2 = struct("MluiCore.Vec2", {
    field("x", ll.f32),
    field("y", ll.f32),
})

T.Rect = struct("MluiCore.Rect", {
    field("x", ll.f32),
    field("y", ll.f32),
    field("w", ll.f32),
    field("h", ll.f32),
})

T.Insets = struct("MluiCore.Insets", {
    field("left", ll.f32),
    field("top", ll.f32),
    field("right", ll.f32),
    field("bottom", ll.f32),
})

T.Color = struct("MluiCore.Color", {
    field("r", ll.f32),
    field("g", ll.f32),
    field("b", ll.f32),
    field("a", ll.f32),
})

T.Range = struct("MluiCore.Range", {
    field("first", ll.u32),
    field("count", ll.u32),
})

T.Size = struct("MluiCore.Size", {
    field("w", ll.f32),
    field("h", ll.f32),
})

T.Viewport = struct("MluiCore.Viewport", {
    field("x", ll.f32),
    field("y", ll.f32),
    field("w", ll.f32),
    field("h", ll.f32),
    field("device_scale", ll.f32),
})

T.Length = struct("MluiStyle.Length", {
    field("kind", ll.u8),
    field("value", ll.f32),
    field("min", ll.f32),
    field("max", ll.f32),
})

T.Track = struct("MluiStyle.Track", {
    field("min", T.Length),
    field("max", T.Length),
    field("repeat_count", ll.u32),
    field("flags", ll.u32),
})

T.EnvClass = struct("MluiEnv.ClassRecord", {
    field("breakpoint", ll.u8),
    field("color_scheme", ll.u8),
    field("motion", ll.u8),
    field("density", ll.u8),
    field("pointer", ll.u8),
    field("platform", ll.u8),
    field("flags", ll.u32),
})

T.StateFacts = struct("MluiModel.StateFacts", {
    field("id", T.Id),
    field("state_mask", ll.u32),
    field("hover_id", T.Id),
    field("focus_id", T.Id),
    field("capture_id", T.Id),
    field("drag_id", T.Id),
    field("active_id", T.Id),
    field("model_epoch", T.Epoch),
})

T.EnvArgs = struct("MluiPhase.EnvArgs", {
    field("env_class", T.EnvClass),
    field("viewport", T.Viewport),
    field("time_ms", ll.u64),
    field("flags", ll.u32),
})

T.ThemeArgs = struct("MluiPhase.ThemeArgs", {
    field("theme_ref", T.Ref),
    field("theme_epoch", T.Epoch),
})

T.ResourceArgs = struct("MluiPhase.ResourceArgs", {
    field("content_epoch", T.Epoch),
    field("paint_epoch", T.Epoch),
    field("image_epoch", T.Epoch),
    field("font_epoch", T.Epoch),
    field("value_epoch", T.Epoch),
    field("text_layout_epoch", T.Epoch),
})

T.InteractionArgs = struct("MluiPhase.InteractionArgs", {
    field("model_epoch", T.Epoch),
    field("hover_id", T.Id),
    field("focus_id", T.Id),
    field("capture_id", T.Id),
    field("drag_id", T.Id),
    field("scroll_epoch", T.Epoch),
})

T.SolveArgs = struct("MluiPhase.SolveArgs", {
    field("viewport_w", ll.f32),
    field("viewport_h", ll.f32),
    field("scroll_epoch", T.Epoch),
    field("text_layout_epoch", T.Epoch),
})

T.RenderArgs = struct("MluiPhase.RenderArgs", {
    field("solve_epoch", T.Epoch),
    field("decor_epoch", T.Epoch),
    field("paint_epoch", T.Epoch),
    field("text_epoch", T.Epoch),
})

T.ReportArgs = struct("MluiPhase.ReportArgs", {
    field("view_epoch", T.Epoch),
    field("model_epoch", T.Epoch),
})

T.IntrinsicSize = struct("MluiMeasure.IntrinsicSize", {
    field("min_w", ll.f32),
    field("min_h", ll.f32),
    field("pref_w", ll.f32),
    field("pref_h", ll.f32),
    field("max_w", ll.f32),
    field("max_h", ll.f32),
    field("baseline", ll.f32),
    field("flags", ll.u32),
})

-- -----------------------------------------------------------------------------
-- Languages.
-- -----------------------------------------------------------------------------

M.Core     = M.vm.language "MluiCore"
M.Env      = M.vm.language "MluiEnv"
M.Theme    = M.vm.language "MluiTheme"
M.Style    = M.vm.language "MluiStyle"
M.Resource = M.vm.language "MluiResource"
M.Auth     = M.vm.language "MluiAuth"
M.Compose  = M.vm.language "MluiCompose"
M.Imported = M.vm.language "MluiImported"
M.Scene    = M.vm.language "MluiScene"
M.Measure  = M.vm.language "MluiMeasure"
M.Solve    = M.vm.language "MluiSolve"
M.View     = M.vm.language "MluiView"
M.Report   = M.vm.language "MluiReport"
M.Input    = M.vm.language "MluiInput"
M.Event    = M.vm.language "MluiEvent"
M.Model    = M.vm.language "MluiModel"

-- -----------------------------------------------------------------------------
-- Core / env / theme / style languages.
-- -----------------------------------------------------------------------------

M.EnvClass = M.Env "Class"
M.EnvClass.Default = {}
M.EnvClass.Custom = {
    breakpoint = ll.u8,
    color_scheme = ll.u8,
    motion = ll.u8,
    density = ll.u8,
    pointer = ll.u8,
    platform = ll.u8,
    flags = ll.u32,
}

M.EnvViewport = M.Env "Viewport"
M.EnvViewport.Viewport = {
    width = ll.f32,
    height = ll.f32,
    device_scale = ll.f32,
}

M.ThemeRecord = M.Theme "Record"
M.ThemeRecord.Palette = { name = T.Id, color = T.Color }
M.ThemeRecord.Spacing = { name = T.Id, value = ll.f32 }
M.ThemeRecord.Font = { name = T.Id, content_ref = T.Ref, font_ref = T.Ref, size = ll.f32, weight = ll.u32, flags = ll.u32 }
M.ThemeRecord.Radius = { name = T.Id, value = ll.f32 }
M.ThemeRecord.Border = { name = T.Id, width = ll.f32, color = T.Color }
M.ThemeRecord.Opacity = { name = T.Id, value = ll.f32 }
M.ThemeRecord.Theme = {
    id = T.Ref,
    epoch = T.Epoch,
    palette = T.Range,
    spacing = T.Range,
    font = T.Range,
    radius = T.Range,
    border = T.Range,
    opacity = T.Range,
}

M.StyleToken = M.Style "Token"
M.StyleToken.Token = {
    id = T.Id,
    conds = T.Range,
    atoms = T.Range,
    order = ll.u32,
    flags = ll.u32,
}

M.StyleCond = M.Style "Cond"
M.StyleCond.State = { mask = ll.u32, op = ll.u8, flags = ll.u32 }
M.StyleCond.Env = { key = ll.u32, op = ll.u8, rhs_i = ll.i32, rhs_f = ll.f32, rhs_id = T.Id, flags = ll.u32 }
M.StyleCond.Resource = { section = ll.u8, ref = T.Ref, epoch = T.Epoch, flags = ll.u32 }

M.StyleAtom = M.Style "Atom"
M.StyleAtom.Display = { kind = ll.u16 }
M.StyleAtom.Position = { kind = ll.u16 }
M.StyleAtom.Width = { length = T.Length }
M.StyleAtom.Height = { length = T.Length }
M.StyleAtom.MinWidth = { length = T.Length }
M.StyleAtom.MinHeight = { length = T.Length }
M.StyleAtom.MaxWidth = { length = T.Length }
M.StyleAtom.MaxHeight = { length = T.Length }
M.StyleAtom.Margin = { insets = T.Insets }
M.StyleAtom.Padding = { insets = T.Insets }
M.StyleAtom.Gap = { x = ll.f32, y = ll.f32 }
M.StyleAtom.FlexDirection = { direction = ll.u8 }
M.StyleAtom.FlexGrow = { value = ll.f32 }
M.StyleAtom.FlexShrink = { value = ll.f32 }
M.StyleAtom.FlexBasis = { length = T.Length }
M.StyleAtom.AlignItems = { value = ll.u16 }
M.StyleAtom.JustifyContent = { value = ll.u16 }
M.StyleAtom.GridTracks = { axis = T.Axis, tracks = T.Range }
M.StyleAtom.Overflow = { axis = T.Axis, policy = T.Policy }
M.StyleAtom.BackgroundColor = { color = T.Color, theme_name = T.Id }
M.StyleAtom.ForegroundColor = { color = T.Color, theme_name = T.Id }
M.StyleAtom.BorderColor = { color = T.Color, theme_name = T.Id }
M.StyleAtom.BorderWidth = { width = ll.f32 }
M.StyleAtom.Radius = { radius = ll.f32 }
M.StyleAtom.Opacity = { value = ll.f32 }
M.StyleAtom.Font = { font_ref = T.Ref, theme_name = T.Id }
M.StyleAtom.FontSize = { size = ll.f32 }
M.StyleAtom.FontWeight = { weight = ll.u32 }
M.StyleAtom.TextAlign = { align = ll.u16 }
M.StyleAtom.LineHeight = { value = ll.f32 }
M.StyleAtom.Cursor = { cursor = ll.u16 }
M.StyleAtom.LayerOrder = { order = ll.i32 }
M.StyleAtom.UserFlag = { flag = ll.u32 }

M.StyleResolved = M.Style "Resolved"
M.StyleResolved.Layout = { id = T.Id, style_index = ll.u32, flags = ll.u32 }
M.StyleResolved.Decor = { id = T.Id, style_index = ll.u32, flags = ll.u32 }
M.StyleResolved.Interaction = { id = T.Id, role = T.Role, policy = T.Policy, flags = ll.u32 }

-- -----------------------------------------------------------------------------
-- Resource language.
-- -----------------------------------------------------------------------------

M.ResourceRecord = M.Resource "Record"
M.ResourceRecord.Content = { ref = T.Ref, byte_len = ll.u32, encoding = ll.u32, layout_affecting = ll.bool, epoch = T.Epoch }
M.ResourceRecord.TextLayout = { ref = T.Ref, content_ref = T.Ref, font_ref = T.Ref, width_constraint = ll.f32, epoch = T.Epoch }
M.ResourceRecord.PaintProgram = { ref = T.Ref, ops = T.Range, epoch = T.Epoch }
M.ResourceRecord.Image = { ref = T.Ref, host_key = ll.u64, width = ll.f32, height = ll.f32, format = ll.u32, epoch = T.Epoch }
M.ResourceRecord.Font = { ref = T.Ref, host_key = ll.u64, family_content_ref = T.Ref, size = ll.f32, weight = ll.u32, style = ll.u32, epoch = T.Epoch }
M.ResourceRecord.Value = { ref = T.Ref, kind = ll.u16, payload_a = ll.u64, payload_b = ll.u64, epoch = T.Epoch }

M.Value = M.Resource "Value"
M.Value.None = {}
M.Value.Bool = { value = ll.bool }
M.Value.I32 = { value = ll.i32 }
M.Value.U32 = { value = ll.u32 }
M.Value.F32 = { value = ll.f32 }
M.Value.F64 = { value = ll.f64 }
M.Value.Id = { value = T.Id }
M.Value.Ref = { value = T.Ref }
M.Value.Range = { min = ll.f32, max = ll.f32, value = ll.f32 }
M.Value.Color = { color = T.Color }
M.Value.Text = { content_ref = T.Ref }
M.Value.Custom = { kind = ll.u16, data_ref = T.Ref }

-- -----------------------------------------------------------------------------
-- Auth and compose languages.  Auth nodes are authored semantic opcodes, not
-- draw commands.  Ranges are row-profile compatible; id/ref 0 means absent.
-- -----------------------------------------------------------------------------

M.AuthNode = M.Auth "Node"
M.AuthNode.Empty = { id = T.Id, state = T.StateFacts, styles = T.Range }
M.AuthNode.Fragment = { id = T.Id, children = T.Range }
M.AuthNode.Box = { id = T.Id, styles = T.Range, children = T.Range, state = T.StateFacts }
M.AuthNode.Text = { id = T.Id, content_ref = T.Ref, styles = T.Range, state = T.StateFacts }
M.AuthNode.TextInline = { id = T.Id, content_ref = T.Ref, styles = T.Range, state = T.StateFacts }
M.AuthNode.TextRef = { id = T.Id, text_layout_ref = T.Ref, styles = T.Range, state = T.StateFacts }
M.AuthNode.Paint = { id = T.Id, paint_ref = T.Ref, paint_range = T.Range, styles = T.Range, state = T.StateFacts }
M.AuthNode.Canvas = { id = T.Id, value_ref = T.Ref, paint_ref = T.Ref, paint_range = T.Range, styles = T.Range, state = T.StateFacts }
M.AuthNode.Image = { id = T.Id, image_ref = T.Ref, styles = T.Range, state = T.StateFacts }
M.AuthNode.Scroll = { id = T.Id, axis = T.Axis, policy = T.Policy, child = ll.u32, styles = T.Range, state = T.StateFacts }
M.AuthNode.InputSurface = { id = T.Id, role = T.Role, policy = T.Policy, child = ll.u32, styles = T.Range, state = T.StateFacts }
M.AuthNode.DragSource = { id = T.Id, policy = T.Policy, child = ll.u32, styles = T.Range, state = T.StateFacts }
M.AuthNode.DropTarget = { id = T.Id, policy = T.Policy, child = ll.u32, styles = T.Range, state = T.StateFacts }
M.AuthNode.FocusScope = { id = T.Id, policy = T.Policy, children = T.Range, styles = T.Range, state = T.StateFacts }
M.AuthNode.Layer = { id = T.Id, layer_kind = ll.u8, order = ll.i32, child = ll.u32, styles = T.Range, state = T.StateFacts }
M.AuthNode.Overlay = { id = T.Id, anchor_id = T.Id, placement = ll.u8, child = ll.u32, styles = T.Range, state = T.StateFacts }
M.AuthNode.Modal = { id = T.Id, barrier_policy = T.Policy, child = ll.u32, styles = T.Range, state = T.StateFacts }
M.AuthNode.TextField = { id = T.Id, content_ref = T.Ref, text_field_state_ref = T.Ref, styles = T.Range, state = T.StateFacts }
M.AuthNode.Slot = { id = T.Id, slot_kind = ll.u16, value_ref = T.Ref, child = ll.u32, styles = T.Range, state = T.StateFacts }

M.ComposeNode = M.Compose "Node"
M.ComposeNode.Panel = { id = T.Id, header = ll.u32, body = ll.u32, footer = ll.u32, styles = T.Range, state = T.StateFacts }
M.ComposeNode.ScrollPanel = { id = T.Id, header = ll.u32, body = ll.u32, footer = ll.u32, axis = T.Axis, styles = T.Range, state = T.StateFacts }
M.ComposeNode.HSplit = { id = T.Id, panes = T.Range, ratios = T.Range, styles = T.Range, state = T.StateFacts }
M.ComposeNode.VSplit = { id = T.Id, panes = T.Range, ratios = T.Range, styles = T.Range, state = T.StateFacts }
M.ComposeNode.Workbench = { id = T.Id, toolbar = ll.u32, sidebar = ll.u32, main = ll.u32, bottom = ll.u32, styles = T.Range, state = T.StateFacts }

M.ImportedNode = M.Imported "Node"
M.ImportedNode.Record = {
    ref = T.Ref,
    kind = T.Kind,
    id = T.Id,
    children = T.Range,
    styles = T.Range,
    content_ref = T.Ref,
    text_layout_ref = T.Ref,
    image_ref = T.Ref,
    paint_ref = T.Ref,
    value_ref = T.Ref,
    other_id = T.Id,
    axis = T.Axis,
    role = T.Role,
    policy = T.Policy,
    state_mask = ll.u32,
    flags = ll.u32,
    epoch = T.Epoch,
}

-- -----------------------------------------------------------------------------
-- Scene / measure / solve / view / report / input / model / event languages.
-- -----------------------------------------------------------------------------

M.SceneLayout = M.Scene "Layout"
M.SceneLayout.Empty = { id = T.Id }
M.SceneLayout.Fragment = { id = T.Id, children = T.Range }
