export func BC_ADDVN() -> i32 return 22 end
export func BC_SUBVN() -> i32 return 23 end
export func BC_MULVN() -> i32 return 24 end
export func BC_DIVVN() -> i32 return 25 end
export func BC_MODVN() -> i32 return 26 end
export func BC_ADDNV() -> i32 return 27 end
export func BC_SUBNV() -> i32 return 28 end
export func BC_MULNV() -> i32 return 29 end
export func BC_DIVNV() -> i32 return 30 end
export func BC_MODNV() -> i32 return 31 end
export func BC_ADDVV() -> i32 return 32 end
export func BC_SUBVV() -> i32 return 33 end
export func BC_MULVV() -> i32 return 34 end
export func BC_DIVVV() -> i32 return 35 end
export func BC_MODVV() -> i32 return 36 end
export func BC_POW()   -> i32 return 37 end
export func BC_CAT()   -> i32 return 38 end

-- Constants
export func BC_KSTR()  -> i32 return 39 end
export func BC_KCDATA() -> i32 return 40 end
export func BC_KSHORT() -> i32 return 41 end
export func BC_KNUM()  -> i32 return 42 end
