export func BC_USETS() -> i32 return 47 end
export func BC_USETN() -> i32 return 48 end
export func BC_USETP() -> i32 return 49 end
export func BC_UCLO()  -> i32 return 50 end
export func BC_FNEW()  -> i32 return 51 end

-- Tables
export func BC_TNEW()  -> i32 return 52 end
export func BC_TDUP()  -> i32 return 53 end
