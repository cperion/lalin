-- core/bytecode.mlua — BCIns layout, decoder accessors, opcode constants.
-- BCIns = u32 (4 bytes): [op:u8@0][A:u8@8][C:u8@16][B:u8@24]
-- D-format: [op:u8@0][A:u8@8][D:u16@16]

local m = module VmCoreBytecode

-- -----------------------------------------------------------------------
-- Bitfield extractors
-- -----------------------------------------------------------------------

export func bc_op(ins: i32) -> i32
    return ins & 0xFF
end

export func bc_a(ins: i32) -> i32
    return (ins >> 8) & 0xFF
end

export func bc_b(ins: i32) -> i32
    return (ins >> 24) & 0xFF
end

export func bc_c(ins: i32) -> i32
    return (ins >> 16) & 0xFF
end

export func bc_d(ins: i32) -> i32
    return (ins >> 16) & 0xFFFF
end

-- -----------------------------------------------------------------------
-- Opcode constants (matching LuaJIT bcdef.h layout)
-- -----------------------------------------------------------------------

-- Comparisons
export func BC_ISLT()  -> i32 return 0  end
export func BC_ISGE()  -> i32 return 1  end
export func BC_ISLE()  -> i32 return 2  end
export func BC_ISGT()  -> i32 return 3  end
export func BC_ISEQV() -> i32 return 4  end
export func BC_ISNEV() -> i32 return 5  end
export func BC_ISEQS() -> i32 return 6  end
export func BC_ISNES() -> i32 return 7  end
export func BC_ISEQN() -> i32 return 8  end
export func BC_ISNEN() -> i32 return 9  end
export func BC_ISEQP() -> i32 return 10 end
export func BC_ISNEP() -> i32 return 11 end

-- Unary test/copy
export func BC_ISTC()  -> i32 return 12 end
export func BC_ISFC()  -> i32 return 13 end
export func BC_IST()   -> i32 return 14 end
export func BC_ISF()   -> i32 return 15 end
export func BC_ISTYPE() -> i32 return 16 end
export func BC_ISNUM() -> i32 return 17 end

-- Constants and moves
export func BC_MOV()   -> i32 return 18 end
export func BC_NOT()   -> i32 return 19 end
export func BC_UNM()   -> i32 return 20 end
export func BC_LEN()   -> i32 return 21 end

